{
    "schemaVersion": 1,
    "id": "zls-api",
    "version": "${version}",
    "name": "ZLS-API",
    "description": "Enables API entitlement for ZLS.",
    "authors": [
        "Zephy"
    ],
    "license": "MIT",
    "contact": {
        "sources": "https://github.com/ZLS-CT/ZLS-API",
        "issues": "https://github.com/ZLS-CT/ZLS-API/issues"
    },
    "environment": "client",
    "entrypoints": {
        "preLaunch": [
            "com.zephy.zlsapi.PreLaunch"
        ]
    },
    "depends": {
        "fabricloader": ">=0.18.0",
        "fabric-api": ">=$min_fabric_api_version",
        "fabric-language-kotlin": ">=1.13.8+kotlin.2.3.0"
    }
}
